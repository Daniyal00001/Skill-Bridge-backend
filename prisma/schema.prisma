generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  CLIENT
  FREELANCER
  ADMIN
}

enum IdVerificationStatus {
  UNSUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  OPEN
  HIRED_PENDING
  IN_PROGRESS
  UNDER_REVIEW
  REVISION_REQUESTED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ProjectSize {
  SMALL
  MEDIUM
  LARGE
}

enum ProposalStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  CANCELLED
}

enum TokenWalletTxType {
  CREDIT
  DEBIT
}

enum TokenTxReason {
  REGISTRATION_BONUS
  MONTHLY_AWARD
  PROPOSAL_SUBMITTED
  PROPOSAL_WITHDRAWN
  ADMIN_GRANT
  ADMIN_DEDUCT
  PROJECT_CANCELLED
}

enum ContractStatus {
  ACTIVE
  OFFER_PENDING
  COMPLETED
  CANCELLED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  FUNDED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeResolution {
  FAVOR_CLIENT
  FAVOR_FREELANCER
  PARTIAL_SPLIT
  PROJECT_CANCELLED
  DISMISSED
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum NotificationType {
  PROPOSAL_RECEIVED
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  PROPOSAL_SHORTLISTED
  PROJECT_STARTED
  MILESTONE_SUBMITTED
  MILESTONE_APPROVED
  PAYMENT_RELEASED
  MESSAGE_RECEIVED
  REVIEW_RECEIVED
  REVIEW_UNLOCKED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  SYSTEM_ALERT
  INVITATION_RECEIVED
  TOKEN_CREDITED
  TOKEN_DEDUCTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  EXPERT
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum SkillStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// USER (Unified auth model — role decides the site)
// ============================================================

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  firstName         String?
  lastName          String?
  email             String    @unique
  passwordHash      String? // null if Google OAuth only
  googleId          String?
  role              Role?
  isEmailVerified   Boolean   @default(false)
  isPaymentVerified Boolean   @default(false)
  isIdVerified      Boolean   @default(false)
  idVerificationStatus IdVerificationStatus @default(UNSUBMITTED)
  idRejectionReason String?
  idDocumentUrl     String?
  phoneNumber       String?
  isPhoneVerified   Boolean   @default(false)
  isBanned          Boolean   @default(false)
  banReason         String?
  profileImage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastActiveAt      DateTime?
  // OTP fields for email change
  pendingEmail      String?
  emailOtp          String?
  emailOtpExpiry    DateTime?
  // OTP fields for phone verification
  phoneOtp          String?
  phoneOtpExpiry    DateTime?
  phoneOtpLastSent  DateTime?
  // Violation tracking
  violationCount    Int       @default(0)
  lastViolationAt   DateTime?
  isFlagged         Boolean   @default(false)

  // Relations
  clientProfile     ClientProfile?
  freelancerProfile FreelancerProfile?
  adminProfile      AdminProfile?

  sentMessages  Message[]      @relation("MessageSender")
  notifications Notification[]
  sessions      Session[]
  loginLogs     LoginLog[]

  // Reviews given and received
  reviewsGiven    Review[] @relation("ReviewGiver")
  reviewsReceived Review[] @relation("ReviewReceiver")

  // Disputes
  disputesAsClient     Dispute[] @relation("DisputeClient")
  disputesAsFreelancer Dispute[] @relation("DisputeFreelancer")

  @@map("users")
}

model LoginLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  role      Role
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_logs")
}

// ============================================================
// SESSION (JWT refresh token tracking)
// ============================================================

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================================
// CLIENT PROFILE
// ============================================================

model ClientProfile {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  userId            String           @unique @db.ObjectId
  fullName          String
  company           String?
  companyType       String? // "Startup", "Enterprise", "Individual", etc.
  industry          String?
  bio               String?
  website           String?
  location          String?
  region            String?
  timezone          String?
  hiringPreference  String? // "Hourly", "Fixed", "Both"
  budgetRange       String? // "Low", "Medium", "High"
  preferredExpLevel ExperienceLevel?
  commMethod        String? // "Slack", "Email", "Chat"
  availability      String? // "Full-time", "Part-time"
  language          String?   // Preferred freelancer language
  locationPref      String?   // "Any location", etc.
  hiringMethod      String?   // "Bidding", "Direct"
  preferredRegion   String?   // Region from DB (e.g. "Asia", "Europe")
  spokenLanguages   String[]  // Client's own languages (up to 3)
  hourlyBudgetMin   Int?      // Preferred freelancer hourly rate - min
  hourlyBudgetMax   Int?      // Preferred freelancer hourly rate - max
  profileCompletion Int              @default(0)
  createdAt         DateTime?        @default(now())
  updatedAt         DateTime?        @updatedAt
  lastLoginAt       DateTime?
  balance           Float            @default(0)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
  invitations Invitation[]
  chatRooms   ChatRoom[]

  // ── Browse System additions ──
  averageRating Float?
  totalHires    Int    @default(0)
  hireRate      Float?
  totalReviews  Int    @default(0)

  @@map("client_profiles")
}

// ============================================================
// FREELANCER PROFILE
// ============================================================

model FreelancerProfile {
  id                      String             @id @default(auto()) @map("_id") @db.ObjectId
  userId                  String             @unique @db.ObjectId
  fullName                String
  bio                     String?
  tagline                 String?
  location                String?
  region                  String?
  timezone                String?
  hourlyRate              Float?
  experienceLevel         ExperienceLevel    @default(ENTRY)
  availability            AvailabilityStatus @default(AVAILABLE)
  responseTime            String? // e.g. "within 2 hours"
  languages               Json?
  profileCompletion       Int                @default(0)
  skillTokenBalance       Int                @default(0) // SkillTokens economy
  createdAt               DateTime?          @default(now())
  updatedAt               DateTime?          @updatedAt
  balance                 Float              @default(0)

  // Social / portfolio links
  github    String?
  linkedin  String?
  portfolio String?
  website   String?

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills            FreelancerSkill[]
  portfolioItems    PortfolioItem[]
  proposals         Proposal[]
  contracts         Contract[]
  certificates      Certificate[]
  educations        Education[]
  invitations       Invitation[]
  chatRooms         ChatRoom[]
  tokenTransactions TokenTransaction[]
  gigs              Gig[]

  // ── Browse System additions ──
  lastLoginAt            DateTime?
  profileCompletionScore Int                 @default(0)
  preferredBudgetMin     Float?
  preferredBudgetMax     Float?
  preferredCategories    String[] // category slugs manually selected by freelancer
  savedProjects          SavedProject[]
  browseInteractions     BrowseInteraction[]
  averageRating          Float?
  totalReviews           Int                 @default(0)

  @@map("freelancer_profiles")
}

// ============================================================
// FREELANCER SKILLS (Many-to-Many via join model)
// ============================================================

model Skill {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  name      String      @unique // e.g. "React", "Graphic Design"
  category  String // e.g. "Frontend", "Design", "Writing"
  status    SkillStatus @default(APPROVED)
  createdAt DateTime    @default(now())

  freelancers   FreelancerSkill[]
  projectSkills ProjectSkill[]

  @@map("skills")
}

model RejectedSkill {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  reason    String?
  createdAt DateTime @default(now())

  @@map("rejected_skills")
}

model FreelancerSkill {
  id                  String @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String @db.ObjectId
  skillId             String @db.ObjectId
  proficiencyLevel    Int    @default(3) // 1-5

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  skill             Skill             @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([freelancerProfileId, skillId])
  @@map("freelancer_skills")
}

// ============================================================
// PORTFOLIO ITEMS (Freelancer's past work showcase)
// ============================================================

model PortfolioItem {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String    @db.ObjectId
  title               String
  description         String?
  imageUrl            String?
  projectUrl          String?
  techStack           String[]
  completedAt         DateTime?
  createdAt           DateTime  @default(now())

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@map("portfolio_items")
}

// ============================================================
// CERTIFICATES (Freelancer credentials)
// ============================================================

model Certificate {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String    @db.ObjectId
  title               String
  issuingOrganization String
  issueDate           DateTime
  expiryDate          DateTime?
  credentialUrl       String?

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ============================================================
// EDUCATION (Freelancer education)
// ============================================================

model Education {
  id                  String  @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String  @db.ObjectId
  school              String
  degree              String
  year                String?

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@map("education")
}

// ============================================================
// GIGS (Freelancer pre-packaged services)
// ============================================================

model Gig {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String            @db.ObjectId
  title               String
  description         String?
  fileUrl             String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  freelancerProfile   FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@map("gigs")
}

// ============================================================
// ADMIN PROFILE
// ============================================================

model AdminProfile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @unique @db.ObjectId
  fullName   String
  department String?
  createdAt  DateTime @default(now())
  lastLoginAt DateTime?

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resolvedDisputes Dispute[]  @relation("DisputeAdmin")
  adminLogs        AdminLog[]

  @@map("admin_profiles")
}

// ============================================================
// PROJECT
// ============================================================

model Project {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  clientProfileId String        @db.ObjectId
  title           String
  shortDesc       String?
  description     String
  requirements    String?
  referenceLinks  String?
  budgetType      String        @default("fixed")
  budget          Float
  size            ProjectSize
  status          ProjectStatus @default(OPEN)
  deadline        DateTime?
  categoryId      String?       @db.ObjectId
  subCategoryId   String?       @db.ObjectId
  attachments     String[]
  experienceLevel String        @default("intermediate")
  hiringMethod    String        @default("bidding")
  language        String        @default("English")
  locationPref    String        @default("Any location")
  languageId      String?       @db.ObjectId
  locationId      String?       @db.ObjectId
  languageObj     Language?     @relation(fields: [languageId], references: [id])
  locationObj     Location?     @relation(fields: [locationId], references: [id])
  proposalCount   Int           @default(0)
  viewCount       Int           @default(0)
  isAiScoped      Boolean       @default(false)
  aiScopeSummary  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clientProfile ClientProfile  @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id])
  subCategory   SubCategory?   @relation(fields: [subCategoryId], references: [id])
  skills        ProjectSkill[]
  proposals     Proposal[]
  contract      Contract?
  invitations   Invitation[]
  chatRooms     ChatRoom[]
  disputes      Dispute[]   // changed from dispute? to disputes[]

  // ── Browse System addition ──
  savedBy SavedProject[]

  @@map("projects")
}

// ============================================================
// PROJECT SKILLS (Required skills for a project)
// ============================================================

model ProjectSkill {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  projectId String @db.ObjectId
  skillId   String @db.ObjectId

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([projectId, skillId])
  @@map("project_skills")
}

// projecvt category
model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique // "Web Development"
  slug      String   @unique // "web"
  icon      String? // store icon name as string e.g. "Layout"
  createdAt DateTime @default(now())

  subCategories SubCategory[]
  projects      Project[]

  @@map("categories")
}

// project subcategory
model SubCategory {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  name       String // "Frontend"
  slug       String // "frontend"
  categoryId String @db.ObjectId

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([categoryId, slug])
  @@map("sub_categories")
}

// ============================================================
// AI SCOPING SESSION (tracks AI assistant conversations)
// ============================================================

model AiScopingSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  input     String // raw user description
  output    Json // structured AI response: {category, size, budgetRange, skills[]}
  projectId String?  @db.ObjectId // linked if user posted the project after
  createdAt DateTime @default(now())

  @@map("ai_scoping_sessions")
}

// ============================================================
// PROPOSAL (Freelancer bids on a project)
// ============================================================

model Proposal {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  projectId           String         @db.ObjectId
  freelancerProfileId String?        @db.ObjectId
  proposedPrice       Float // bid amount
  deliveryTime        Int // in days
  coverLetter         String
  attachments         String[] // optional file URLs
  tokenCost           Int            @default(0) // SkillTokens spent on this proposal
  status               ProposalStatus     @default(PENDING)
  proposalMilestones   Json?              // optional milestone plan submitted by freelancer
  clientRequestedMilestones Json?         // modified milestones proposed by client
  negotiationStatus     String?            // CLIENT_PROPOSED, FREELANCER_ACCEPTED, FREELANCER_REJECTED, CLIENT_PROPOSED_REVISIONS
  generalRevisionLimit Int                @default(3) // default revisions if no milestones provided
  clientRequestedRevisions Int?           // if client requests more revisions without changing milestones
  submittedAt          DateTime           @default(now())
  updatedAt           DateTime       @updatedAt

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancerProfile FreelancerProfile? @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@unique([projectId, freelancerProfileId]) // one proposal per freelancer per project
  @@map("proposals")
}

// ============================================================
// TOKEN TRANSACTION (SkillToken economy ledger)
// ============================================================

model TokenTransaction {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String            @db.ObjectId
  type                TokenWalletTxType
  reason              TokenTxReason
  amount              Int // always positive; type determines direction
  balanceAfter        Int // snapshot of balance after transaction
  description         String? // human-readable note
  relatedProposalId   String?           @db.ObjectId // linked proposal if applicable
  createdAt           DateTime          @default(now())

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@map("token_transactions")
}

// ============================================================
// INVITATION (Client invites freelancer to a project)
// ============================================================

model Invitation {
  id                  String           @id @default(auto()) @map("_id") @db.ObjectId
  projectId           String           @db.ObjectId
  freelancerProfileId String?          @db.ObjectId
  clientProfileId     String           @db.ObjectId
  message             String?
  status              InvitationStatus @default(PENDING)
  milestones          Json?            // proposed milestones
  revisionsAllowed    Int              @default(3) // global revision limit fallback
  budget              Float?           // budget specific to this invite
  attachments         String[]         @default([]) // supporting documents
  createdAt           DateTime         @default(now())

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancerProfile FreelancerProfile? @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  clientProfile     ClientProfile     @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([projectId, freelancerProfileId]) // one invitation per freelancer per project
  @@map("invitations")
}

// ============================================================
// CONTRACT (Created when a proposal is accepted)
// ============================================================

model Contract {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  projectId           String         @unique @db.ObjectId
  freelancerProfileId String         @db.ObjectId
  agreedPrice         Float
  startDate           DateTime       @default(now())
  endDate             DateTime?
  status              ContractStatus @default(ACTIVE)
  milestonesModifiedByClient Boolean @default(false)
  termsAccepted       Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  milestones        Milestone[]
  payments   Payment[]
  chatRooms  ChatRoom[]

  @@map("contracts")
}

// ============================================================
// MILESTONE (Deliverable checkpoints within a contract)
// ============================================================

model Milestone {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  contractId   String          @db.ObjectId
  order        Int             @default(0) // display order
  title        String
  description  String?
  amount       Float // payment for this milestone
  dueDate      DateTime?
  status           MilestoneStatus @default(PENDING)
  deliverables     String?         // freelancer's submission note
  revisionNote     String?         // client's feedback for revision
  allowedRevisions Int             @default(3) // -1 for unlimited
  revisionsUsed    Int             @default(0)
  submittedAt      DateTime?
  approvedAt       DateTime?
  attachments  String[] // submitted file URLs
  history      Json?    // Array of event objects: { type, timestamp, content, attachments }

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payment  Payment?

  @@map("milestones")
}

// ============================================================
// PAYMENT (Escrow and release tracking)
// ============================================================

model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  contractId    String        @db.ObjectId
  milestoneId   String?       @unique @db.ObjectId
  amount        Float
  status        PaymentStatus @default(PENDING)
  transactionId String? // from payment gateway (e.g. Stripe)
  paidAt        DateTime?
  releasedAt    DateTime?
  createdAt     DateTime      @default(now())

  contract  Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id])

  @@map("payments")
}

// ============================================================
// CHAT ROOM (One per contract or for recruitment)
// ============================================================

model ChatRoom {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  contractId          String?  @db.ObjectId
  projectId           String?  @db.ObjectId
  freelancerProfileId String?  @db.ObjectId
  clientProfileId     String?  @db.ObjectId
  isActiveAI          Boolean  @default(false)
  createdAt           DateTime @default(now())

  contract          Contract?          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  project           Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancerProfile FreelancerProfile? @relation(fields: [freelancerProfileId], references: [id])
  clientProfile     ClientProfile?     @relation(fields: [clientProfileId], references: [id])
  clientDeleted     Boolean            @default(false)
  freelancerDeleted Boolean            @default(false)
  messages          Message[]

  @@map("chat_rooms")
}

// ============================================================
// MESSAGE (Real-time chat via Socket.IO)
// ============================================================

model Message {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  chatRoomId String      @db.ObjectId
  senderId   String      @db.ObjectId
  content    String
  type       MessageType @default(TEXT)
  fileUrl    String? // if type = FILE
  isRead     Boolean     @default(false)
  isAiMessage Boolean     @default(false)
  sentAt     DateTime    @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ============================================================
// REVIEW (Blind review system)
// ============================================================

model Review {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  contractId     String    @db.ObjectId
  giverId        String    @db.ObjectId // who wrote the review
  receiverId     String    @db.ObjectId // who gets the review
  rating         Int       // 1-5
  comment        String?
  isRevealed     Boolean   @default(false) // blind until both submit or timeout
  submittedAt    DateTime  @default(now())
  revealedAt     DateTime?
  reviewDeadline DateTime? // 7 days after contract completion
  giverRole      String?   // "CLIENT" | "FREELANCER" — for UI context

  giver    User @relation("ReviewGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiver User @relation("ReviewReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([contractId, giverId]) // one review per person per contract
  @@map("reviews")
}



// ============================================================
// DISPUTE
// ============================================================

model Dispute {
  id               String             @id @default(auto()) @map("_id") @db.ObjectId
  projectId        String             @db.ObjectId  // no longer unique — allows one per party
  clientId         String             @db.ObjectId
  freelancerId     String             @db.ObjectId
  adminId          String?            @db.ObjectId
  disputeType      String             @default("PAYMENT") // PAYMENT | SCOPE | DEADLINE | QUALITY | REVISION | DELIVERABLES | IP
  filedBy          String             @default("CLIENT")  // CLIENT | FREELANCER
  reason           String
  summary          String?
  details          String?
  evidenceUrls     String[]           @default([])
  status           DisputeStatus      @default(OPEN)
  resolution       DisputeResolution?
  resolutionNote   String?
  openedAt         DateTime           @default(now())
  resolvedAt       DateTime?
  updatedAt        DateTime           @updatedAt
  relatedDisputeId String?            @db.ObjectId  // links to the other party's dispute on same project

  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client            User          @relation("DisputeClient", fields: [clientId], references: [id])
  freelancer        User          @relation("DisputeFreelancer", fields: [freelancerId], references: [id])
  admin             AdminProfile? @relation("DisputeAdmin", fields: [adminId], references: [id])
  relatedDispute    Dispute?      @relation("RelatedDisputes", fields: [relatedDisputeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  counterDisputes   Dispute[]     @relation("RelatedDisputes")

  @@map("disputes")
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  type      NotificationType
  title     String
  body      String
  link      String? // deep-link to relevant page
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================================
// ADMIN LOG (Audit trail for admin actions)
// ============================================================

model AdminLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  adminProfileId String   @db.ObjectId
  action         String // e.g. "BANNED_USER", "RESOLVED_DISPUTE"
  targetType     String // e.g. "User", "Project", "Dispute"
  targetId       String   @db.ObjectId
  note           String?
  createdAt      DateTime @default(now())

  adminProfile AdminProfile @relation(fields: [adminProfileId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

// ============================================================
// PLATFORM SETTINGS (Admin-controlled global settings)
// ============================================================

model PlatformSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique // e.g. "platform_fee_percentage"
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ============================================================
// AI SESSION & MESSAGES
// ============================================================

model AISession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?
  createdAt DateTime @default(now())
  messages  AIMessage[]

  @@map("ai_sessions")
}

model AIMessage {
  id        String   @id @default(uuid()) @map("_id")
  role      String
  content   String
  session   AISession @relation(fields: [sessionId], references: [id])
  sessionId String   @db.ObjectId
  createdAt DateTime @default(now())
}

model EmailVerification {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  otp          String
  name         String
  passwordHash String
  role         Role
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("email_verifications")
}

model Language {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  code      String?   @unique // e.g., "en", "es"
  createdAt DateTime  @default(now())
  projects  Project[]

  @@map("languages")
}

model Location {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  region    String? // e.g., "Asia", "Europe"
  phoneCode String? // e.g., "+92"
  createdAt DateTime  @default(now())
  projects  Project[]

  @@map("locations")
}

enum InteractionType {
  VIEW
  SAVE
  UNSAVE
  APPLY
  CATEGORY_CLICK
  QUICK_APPLY
}

model SavedProject {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String   @db.ObjectId
  projectId           String   @db.ObjectId
  savedAt             DateTime @default(now())

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([freelancerProfileId, projectId])
  @@map("saved_projects")
}

model BrowseInteraction {
  id                  String          @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String          @db.ObjectId
  projectId           String?         @db.ObjectId
  categorySlug        String?
  type                InteractionType
  metadata            Json?
  createdAt            DateTime        @default(now())

  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@index([freelancerProfileId, type, createdAt])
  @@map("browse_interactions")

}

model AiMemory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  type      String   // PREFERENCE, DEAL, CONTEXT
  content   Json
  createdAt DateTime @default(now())

  @@map("ai_memory")
}

model NegotiationInsight {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  chatRoomId      String   @db.ObjectId @unique
  initialPrice    Float
  finalPrice      Float?
  discount        Float?
  durationMinutes Int?
  createdAt       DateTime @default(now())

  @@map("negotiation_insights")
}

model FreelancerEvaluation {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  freelancerProfileId String   @db.ObjectId
  chatRoomId          String?  @db.ObjectId
  score               Int      // 0-100
  communication       Int      // 1-10
  priceFit            Int      // 1-10
  skillMatch          Int      // 1-10
  evaluatedAt         DateTime @default(now())

  @@map("freelancer_evaluations")
}

